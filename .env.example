# JSON string containing app configuration
# Example: {"sensors":[{"id":"sensor1","name":"Front Door","delaySeconds":90}],"hvacUnits":[{"id":"unit1","name":"Living Room AC","iftttEvent":"turn_off_ac"}],"yolink":{"baseUrl":"https://api.yosmart.com/open/yolink/v2/api"},"checkStateUrl":"https://your-app.vercel.app/api/check-state"}
APP_CONFIG=

# YoLink API credentials
YOLINK_UA_CID=
YOLINK_SECRET_KEY=

# IFTTT Webhook key
IFTTT_WEBHOOK_KEY=

# QStash credentials
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
