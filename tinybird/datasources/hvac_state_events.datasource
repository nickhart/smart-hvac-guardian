DESCRIPTION >
    HVAC unit on/off state change events

SCHEMA >
    timestamp DateTime `json:$.timestamp`,
    request_id String `json:$.request_id`,
    hvac_id String `json:$.hvac_id`,
    event String `json:$.event`,
    was_exposed UInt8 `json:$.was_exposed`,
    turnoff_scheduled UInt8 `json:$.turnoff_scheduled`

ENGINE "MergeTree"
ENGINE_SORTING_KEY "timestamp, hvac_id"
